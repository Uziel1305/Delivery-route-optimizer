# Copy to .env and fill in real values. .env is gitignored.

POSTGRES_USER=route_optimizer
POSTGRES_PASSWORD=change_me
POSTGRES_DB=route_optimizer
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://route_optimizer:change_me@postgres:5432/route_optimizer

RABBITMQ_DEFAULT_USER=route_optimizer
RABBITMQ_DEFAULT_PASS=change_me
CELERY_BROKER_URL=amqp://route_optimizer:change_me@rabbitmq:5672//

JWT_SECRET_KEY=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

OSRM_BASE_URL=http://osrm-routed:5000
PHOTON_BASE_URL=https://photon.komoot.io
